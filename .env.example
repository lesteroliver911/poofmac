# PoofMac — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# At minimum, provide ONE API key OR install Ollama with a supported model.
# ─────────────────────────────────────────────────────────────────────────────

# ── CLOUD API KEYS (optional — leave blank to use local Ollama) ───────────────

# Anthropic API Key → https://console.anthropic.com
# Priority 1 if set.
ANTHROPIC_API_KEY=

# OpenRouter API Key → https://openrouter.ai
# Priority 2 if set. Unlocks Claude, GPT, Gemini, DeepSeek and more.
OPENROUTER_API_KEY=

# OpenAI API Key → https://platform.openai.com
# Priority 3 if set.
OPENAI_API_KEY=

# ── MODEL SELECTION ───────────────────────────────────────────────────────────

# Cloud model to use (Anthropic / OpenRouter / OpenAI)
# Recommended  : claude-sonnet-4-6
# Budget option: claude-haiku-4-5
# OpenAI       : gpt-4o
PREFERRED_CLOUD_MODEL=claude-sonnet-4-6

# Local/cloud Ollama model to use when no cloud key is configured.
#
# Ollama cloud (subscription needed, no local RAM required):
#   deepseek-v4-flash:cloud    — fast, great for daily scans
#   gemma4:31b-cloud           — strong tool-calling
#   qwen3.5:cloud              — excellent reasoning
#
# Ollama local (runs on your Mac):
#   24 GB RAM Mac : qwen3.6:35b-a3b   (MoE — 3B active, excellent)
#   16 GB RAM Mac : qwen3.6:27b       (strong structured output)
#   12 GB RAM Mac : qwen2.5:14b       (solid, widely available)
#   8 GB RAM Mac  : llama3.1:8b       (minimum viable)
PREFERRED_LOCAL_MODEL=qwen2.5:14b

# ── SAFETY ────────────────────────────────────────────────────────────────────

# Safe Mode: true = scan and report only, ZERO file deletions possible.
# Recommended for first run or sharing with others.
SAFE_MODE=false
